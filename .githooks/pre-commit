#!/usr/bin/env bash
# Rebuild dist/proxy-man.sh from src/ and stage it when the artifact changes.
set -euo pipefail

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
cd "$ROOT_DIR"

[[ -d src ]] || exit 0
[[ -x scripts/build.sh ]] || chmod +x scripts/build.sh

./scripts/build.sh >/dev/null

if ! git diff --quiet -- dist/proxy-man.sh 2>/dev/null \
  || ! git diff --cached --quiet -- dist/proxy-man.sh 2>/dev/null \
  || [[ -n $(git status --porcelain --untracked-files=normal -- dist/proxy-man.sh) ]]; then
  git add -- dist/proxy-man.sh
  printf 'pre-commit: refreshed dist/proxy-man.sh\n'
fi

exit 0
